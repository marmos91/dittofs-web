# Copy to .env for local dev. In production, set these in the Cloudflare Pages
# project settings. PUBLIC_* values are exposed to the browser.

# Canonical site URL (SEO/OG). Defaults to https://dittofs.io.
PUBLIC_SITE_URL=https://dittofs.io

# Analytics. Leave BOTH empty to disable the cookie banner and all tags.
PUBLIC_GTM_ID=
PUBLIC_FB_PIXEL_ID=

# Cloudflare Turnstile public site key (leave empty to disable the widget).
PUBLIC_TURNSTILE_SITEKEY=

# --- Server-side secrets for the /api/contact Pages Function ---
# Set these as encrypted env vars in Cloudflare Pages. Do NOT commit real values.
# RESEND_API_KEY=re_xxx
# CONTACT_TO_EMAIL=sales@yourdomain.com
# CONTACT_FROM_EMAIL=DittoFS <onboarding@resend.dev>
# TURNSTILE_SECRET=0x_xxx
