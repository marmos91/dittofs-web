---
import Base from "../layouts/Base.astro";
import Gateway from "../components/landing/Gateway.astro";
import Terminal from "../components/landing/Terminal.astro";
import HowItWorks from "../components/landing/HowItWorks.astro";
import WritePath from "../components/landing/WritePath.astro";
import { getStars, formatStars, getLatestRelease } from "../lib/github";

const GITHUB = "https://github.com/marmos91/dittofs";
const stars = formatStars(await getStars());
const version = await getLatestRelease();

const heroStats = [
  { label: "Versatile", k: "NFS + SMB", v: "served together" },
  { label: "Compatible", k: "99.99% POSIX", v: "drop-in for clients" },
  { label: "Simple", k: "Userspace", v: "no FUSE, no kernel" },
  { label: "Portable", k: "One binary", v: "pure Go" },
];

// Six headline capabilities get full cards; the rest sit in a compact list
// below so the section reads as "six reasons + the long tail," not a wall of 11.
const features = [
  {
    tag: "protocols",
    title: "Multi-protocol, one server",
    body: "NFS and SMB run at the same time on the same server, serving the same files to Linux, Windows, and macOS.",
    icon: "layers",
  },
  {
    tag: "backends",
    title: "Pluggable storage",
    body: "Mix metadata stores (memory, BadgerDB, PostgreSQL) and block stores (filesystem, S3) per share.",
    icon: "plug",
  },
  {
    tag: "runtime",
    title: "Runs in userspace",
    body: "No FUSE, no kernel modules, no root. DittoFS runs as an ordinary process you can start anywhere.",
    icon: "shield",
  },
  {
    tag: "security",
    title: "Client-side encryption",
    body: "Per-remote envelope encryption with AES-256-GCM or ChaCha20-Poly1305, keyed locally or via KMIP. Blocks are encrypted before they leave the server, so the object store only sees ciphertext.",
    icon: "lock",
  },
  {
    tag: "efficiency",
    title: "Deduplication",
    body: "Files split into content-defined chunks, addressed by BLAKE3 hash. Identical chunks across files are stored once.",
    icon: "dedup",
  },
  {
    tag: "control plane",
    title: "REST control plane",
    body: "Manage users, groups, and shares through a JWT-authenticated REST API or the dfsctl command line. Provision by script, not by editing config files.",
    icon: "code",
  },
];

// The long tail — shown as a tighter list under the six cards.
const featuresMore = [
  {
    title: "Easy to containerize",
    body: "One static Go binary drops into any container or orchestrator.",
    icon: "container",
  },
  {
    title: "Compression",
    body: "Remote block stores compress with zstd or lz4 before upload.",
    icon: "compress",
  },
  {
    title: "Share snapshots",
    body: "Point-in-time holds with no data copy. Restore from CLI or REST.",
    icon: "camera",
  },
  {
    title: "Kerberos and signing",
    body: "RPCSEC_GSS, SPNEGO Kerberos, SMB3 signing and transport encryption.",
    icon: "key",
  },
  {
    title: "Cross-platform ACLs",
    body: "NFSv4 and Windows/SMB ACLs enforced consistently across clients.",
    icon: "shieldcheck",
  },
];

// Honest protocol capability matrix. y = yes, p = partial, n = not applicable.
const matrixCols = ["NFSv3", "NFSv4 / 4.1", "SMB2 / 3"];
const matrixRows = [
  { label: "Mount & file I/O", v: ["y", "y", "y"] },
  { label: "ACLs", v: ["n", "y", "y"] },
  { label: "Kerberos auth", v: ["y", "y", "y"] },
  { label: "Leases / delegations", v: ["n", "y", "y"] },
  { label: "Wire encryption", v: ["p", "p", "y"] },
  { label: "Client-side encryption", v: ["y", "y", "y"] },
  { label: "Snapshots", v: ["y", "y", "y"] },
];

const useCases = [
  {
    title: "Multi-tenant cloud",
    body: "Isolated shares, per-share stores, and client-side encryption for tenants that share the same infrastructure.",
    icon: "globe",
  },
  {
    title: "Tiered storage",
    body: "A fast local cache fronts durable S3. Writes land locally and sync to the remote in the background.",
    icon: "swap",
  },
  {
    title: "Hybrid Linux and Windows",
    body: "Serve Linux over NFS and Windows or macOS over SMB from one server, backed by the same data.",
    icon: "layers",
  },
  {
    title: "Dev and test",
    body: "Spin up an in-memory filesystem in one command. No FUSE, no privileges, no external services to stand up.",
    icon: "beaker",
  },
  {
    title: "Cloud-native deployments",
    body: "A single userspace binary drops into Kubernetes with the official operator. Scale shares, not kernels.",
    icon: "container",
  },
  {
    title: "Backup and recovery",
    body: "Point-in-time share snapshots with no data copy, restorable from the CLI or REST API, guard against accidental deletes.",
    icon: "camera",
  },
];

const backends = [
  "AWS S3",
  "Cubbit DS3",
  "MinIO",
  "Ceph",
  "Wasabi",
  "Backblaze B2",
  "Scaleway",
  "Filesystem",
  "any S3-compatible",
];

const pillars = [
  {
    title: "Multi-cloud and hybrid",
    body: "Serve the same data from AWS, MinIO, Ceph, Cubbit DS3, or a local disk. Move between clouds and the edge without re-platforming.",
    icon: "globe",
  },
  {
    title: "No appliance to buy",
    body: "Open-source software that runs on hardware you already own. No proprietary NAS or SAN controllers, no per-shelf licensing, no forklift upgrades. Compute and storage scale on their own.",
    icon: "coins",
  },
  {
    title: "Runs anywhere",
    body: "One static binary on a laptop, a bare-metal edge box, a VM in any cloud, or Kubernetes with the official operator.",
    icon: "cpu",
  },
];

const roadmap = [
  {
    phase: "Shipped",
    state: "done",
    note: "Working today",
    items: [
      "Multi-protocol engine — NFSv3/v4/4.1 and SMB2/3",
      "Pluggable metadata and block stores",
      "Client-side encryption, dedup, and compression",
      "REST control plane, CLI, and Kubernetes operator",
    ],
  },
  {
    phase: "In progress",
    state: "now",
    note: "Where we are",
    items: [
      "Stability and performance hardening",
      "Wider test coverage and benchmarks",
      "Deployment guides and reference docs",
    ],
  },
  {
    phase: "Next",
    state: "planned",
    note: "What's coming",
    items: [
      "Production-ready 1.0",
      "Managed PRO console with role-based access",
      "Commercial support tiers",
    ],
  },
];

const icons: Record<string, string> = {
  shield: `<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/>`,
  layers: `<path d="M12 3l9 5-9 5-9-5 9-5z"/><path d="M3 12l9 5 9-5"/>`,
  plug: `<path d="M9 3v6M15 3v6"/><path d="M7 9h10v3a5 5 0 0 1-10 0V9z"/><path d="M12 17v4"/>`,
  lock: `<rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/>`,
  camera: `<path d="M3 8h4l2-2h6l2 2h4v12H3V8z"/><circle cx="12" cy="13" r="3.5"/>`,
  container: `<path d="M12 2l8 4.5v9L12 20l-8-4.5v-9L12 2z"/><path d="M12 11l8-4.5M12 11v9M12 11L4 6.5"/>`,
  dedup: `<rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/>`,
  compress: `<path d="M8 4v4H4M16 4v4h4M8 20v-4H4M16 20v-4h4"/>`,
  key: `<circle cx="8" cy="8" r="4"/><path d="M11 11l9 9M17 17l2-2M14 14l2-2"/>`,
  shieldcheck: `<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 11l2 2 4-4"/>`,
  code: `<path d="M8 4l-4 8 4 8M16 4l4 8-4 8"/>`,
  globe: `<circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3c2.6 2.7 2.6 15.3 0 18M12 3c-2.6 2.7-2.6 15.3 0 18"/>`,
  swap: `<path d="M4 9h13l-4-4M20 15H7l4 4"/>`,
  beaker: `<path d="M9 3h6M10 3v6L5 19a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1l-5-10V3"/><path d="M7.5 14h9"/>`,
  coins: `<ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6"/><path d="M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6"/>`,
  cpu: `<rect x="6" y="6" width="12" height="12" rx="2"/><rect x="9.5" y="9.5" width="5" height="5" rx="1"/><path d="M9 2v2.5M15 2v2.5M9 19.5V22M15 19.5V22M2 9h2.5M2 15h2.5M19.5 9H22M19.5 15H22"/>`,
};

const statusMark = (s: string) =>
  s === "y" ? "supported" : s === "p" ? "partial" : "not applicable";
---

<Base>
  <!-- ===================== HERO ===================== -->
  <section class="section-screen relative overflow-hidden">
    <div class="bg-grid pointer-events-none absolute inset-0 opacity-[0.35]"></div>
    <div
      class="glow-accent pointer-events-none absolute -top-32 left-1/2 h-[560px] w-[920px] -translate-x-1/2 opacity-50"
    >
    </div>

    <div
      class="relative mx-auto grid max-w-7xl items-center gap-10 px-6 py-20 lg:grid-cols-[1fr_1.18fr] lg:py-28"
    >
      <div>
        <div class="rise mb-5 flex flex-wrap items-center gap-3">
          <a
            href="/#roadmap"
            class="inline-flex items-center gap-2 rounded-full border border-accent/30 bg-accent/10 px-3.5 py-1.5 text-sm font-medium text-accent-bright transition-colors hover:border-accent/60 hover:bg-accent/15"
          >
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-bright opacity-60"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-bright"></span>
            </span>
            Building in the open
            <span aria-hidden="true">&rarr;</span>
          </a>
          <a
            href={`${GITHUB}/releases`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 rounded-full border border-border-bright px-3 py-1.5 font-mono text-xs text-fg-muted transition-colors hover:border-accent/50 hover:text-fg"
            data-gh-version
            hidden={!version}
            aria-label="Latest DittoFS release"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r="1.2" fill="currentColor"/></svg>
            <span class="gh-version-n">{version}</span>
          </a>
        </div>
        <h1
          class="rise text-balance text-4xl font-bold leading-[1.04] tracking-tight sm:text-5xl lg:text-6xl"
        >
          One filesystem.<br />
          <span class="text-accent-bright">Every protocol.</span> Any backend.
        </h1>
        <p
          class="rise mt-6 max-w-xl text-pretty text-lg leading-relaxed text-fg-muted"
          style="animation-delay:80ms"
        >
          Simple to run, versatile by design. DittoFS is one Go binary that
          serves your files over NFS and SMB, and stores them on any backend you
          choose &mdash; from local disk to S3. No FUSE, no kernel modules, no
          appliance.
        </p>

        <div
          class="rise mt-9 flex flex-wrap items-center gap-4"
          style="animation-delay:160ms"
        >
          <a href="/docs/overview/getting-started/" class="btn btn-primary group">
            Get started
            <span class="arrow" aria-hidden="true">&rarr;</span>
          </a>
          <a href={GITHUB} target="_blank" rel="noopener" class="btn btn-secondary">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"
              ><path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
              ></path></svg
            >
            View on GitHub
            <span
              class="ml-1 flex items-center gap-1 border-l border-border-bright pl-2.5 font-mono text-[13px] tabular-nums text-fg-faint"
              data-gh-stars
              hidden={!stars}
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01L12 2z"/></svg>
              <span class="gh-stars-n">{stars}</span>
            </span>
          </a>
        </div>

        <dl
          class="rise mt-12 grid max-w-xl grid-cols-2 gap-px overflow-hidden rounded-lg border border-border bg-border sm:grid-cols-4"
          style="animation-delay:240ms"
        >
          {
            heroStats.map((s) => (
              <div class="bg-ink-900 px-4 py-4 transition-colors hover:bg-ink-800">
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-accent-bright">
                  {s.label}
                </p>
                <dt class="mt-2 whitespace-nowrap text-sm font-bold leading-none text-fg">
                  {s.k}
                </dt>
                <dd class="mt-1.5 text-xs leading-tight text-fg-faint">{s.v}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="rise" style="animation-delay:140ms">
        <Gateway />
      </div>
    </div>
  </section>

  <!-- ===================== FEATURES ===================== -->
  <section id="features" class="section-screen border-t border-border/60">
    <div class="mx-auto max-w-7xl px-6 py-24">
      <div class="max-w-2xl" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          Why DittoFS
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">
          Storage decisions, decoupled from protocols
        </h2>
        <p class="mt-4 text-fg-muted">
          Pick the interface your clients speak and the backend your data lives
          on, independently, per share.
        </p>
      </div>

      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          features.map((f, i) => (
            <div
              class="group relative overflow-hidden rounded-lg border border-border bg-ink-950/50 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent/50 hover:bg-ink-900/60 hover:shadow-[0_24px_50px_-30px_rgba(0,101,255,0.5)]"
              data-reveal
              style={`transition-delay:${(i % 3) * 70}ms`}
            >
              <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
              <div
                class="glow-accent pointer-events-none absolute -right-10 -top-10 h-32 w-32 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
              />
              <div class="relative flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-md border border-accent/30 bg-accent/10 text-accent-bright transition-all duration-300 group-hover:border-accent group-hover:bg-accent/20">
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={icons[f.icon]}
                  />
                </div>
                <span class="font-mono text-xs text-fg-faint">
                  {String(i + 1).padStart(2, "0")}
                </span>
              </div>
              <p class="relative mt-5 font-mono text-[11px] uppercase tracking-[0.18em] text-accent-bright/80">
                {f.tag}
              </p>
              <h3 class="relative mt-1.5 text-base font-bold">{f.title}</h3>
              <p class="relative mt-2 text-sm leading-relaxed text-fg-muted">{f.body}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-12 border-t border-border/60 pt-10" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-fg-faint">
          And more
        </p>
        <ul class="mt-6 grid gap-x-10 gap-y-5 sm:grid-cols-2 lg:grid-cols-3">
          {
            featuresMore.map((f) => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-accent/30 bg-accent/10 text-accent-bright">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={icons[f.icon]}
                  />
                </span>
                <span>
                  <span class="text-sm font-semibold text-fg">{f.title}</span>
                  <span class="mt-0.5 block text-sm leading-relaxed text-fg-muted">{f.body}</span>
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- ===================== NO LOCK-IN ===================== -->
  <section id="storage" class="section-screen relative overflow-hidden border-t border-border/60">
    <div class="bg-grid pointer-events-none absolute inset-0 opacity-[0.22]"></div>
    <div
      class="glow-accent pointer-events-none absolute left-1/2 top-10 h-[360px] w-[760px] -translate-x-1/2 opacity-30"
    >
    </div>
    <div class="relative mx-auto max-w-7xl px-6 py-24">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          No lock-in
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">
          Object storage, with filesystem semantics
        </h2>
        <p class="mt-4 text-fg-muted">
          DittoFS puts real NFS and SMB on top of any S3-compatible object store.
          Serve the same bucket from any cloud, on-prem, or the edge. Your data
          follows your architecture, not a vendor.
        </p>
      </div>

      <div class="mt-12" data-reveal>
        <p class="text-center font-mono text-xs uppercase tracking-[0.2em] text-fg-faint">
          Bring your own backend
        </p>
        <div class="mx-auto mt-6 flex max-w-4xl flex-wrap items-center justify-center gap-3">
          {
            backends.map((b) => (
              <span class="rounded-lg border border-border-bright bg-ink-900 px-4 py-2 text-sm text-fg-muted transition-colors hover:border-accent hover:text-fg">
                {b}
              </span>
            ))
          }
          <a
            href="/docs/storage/implementing-stores/"
            class="group inline-flex items-center gap-1.5 rounded-lg border border-dashed border-accent/70 bg-accent/10 px-4 py-2 text-sm font-medium text-accent-bright transition-colors hover:border-accent hover:bg-accent/20"
          >
            + write your own
            <span class="arrow" aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>

      <div class="mt-16 grid gap-5 md:grid-cols-3">
        {
          pillars.map((p, i) => (
            <div
              class="rounded-xl border border-border bg-ink-950/60 p-7"
              data-reveal
              style={`transition-delay:${i * 80}ms`}
            >
              <div class="flex h-11 w-11 items-center justify-center rounded-lg border border-accent/30 bg-accent/10 text-accent-bright">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={icons[p.icon]}
                />
              </div>
              <h3 class="mt-5 text-lg font-bold">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-fg-muted">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== HOW IT WORKS ===================== -->
  <section id="how-it-works" class="section-screen border-t border-border/60 bg-ink-900/40">
    <div class="mx-auto max-w-7xl px-6 py-24">
      <div class="max-w-2xl" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          How it works
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">Three clean layers</h2>
        <p class="mt-4 text-fg-muted">
          Adapters speak protocols. The runtime owns every operation. Stores hold
          the bytes. Each layer is replaceable on its own.
        </p>
      </div>

      <div class="mt-16">
        <HowItWorks />
      </div>
    </div>
  </section>

  <!-- ===================== MATRIX + TERMINAL ===================== -->
  <section id="protocols" class="section-screen border-t border-border/60">
    <div class="mx-auto grid max-w-7xl gap-14 px-6 py-24 lg:grid-cols-2 lg:items-start">
      <div data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          Capabilities
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">What each protocol does</h2>
        <p class="mt-4 text-fg-muted">
          The same data, exposed through different protocols. Capabilities follow
          what each protocol can express.
        </p>

        <div class="mt-8 overflow-hidden rounded-xl border border-border">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="bg-ink-900">
                <th class="px-4 py-3 text-left font-semibold text-fg">Capability</th>
                {
                  matrixCols.map((c) => (
                    <th class="px-3 py-3 text-center font-mono text-xs font-semibold text-fg-muted">
                      {c}
                    </th>
                  ))
                }
              </tr>
            </thead>
            <tbody>
              {
                matrixRows.map((row) => (
                  <tr class="border-t border-border">
                    <td class="px-4 py-3 text-fg-muted">{row.label}</td>
                    {row.v.map((s) => (
                      <td class="px-3 py-3 text-center">
                        <span class="sr-only">{statusMark(s)}</span>
                        {s === "y" && (
                          <span class="mx-auto block h-2.5 w-2.5 rounded-full bg-accent" aria-hidden="true" />
                        )}
                        {s === "p" && (
                          <span class="mx-auto block h-2.5 w-2.5 rounded-full border border-accent" aria-hidden="true" />
                        )}
                        {s === "n" && (
                          <span class="mx-auto block h-px w-3 bg-fg-faint" aria-hidden="true" />
                        )}
                      </td>
                    ))}
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="mt-3 flex flex-wrap items-center gap-4 font-mono text-xs text-fg-faint">
          <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-accent"></span> supported</span>
          <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full border border-accent"></span> partial</span>
          <span class="flex items-center gap-1.5"><span class="h-px w-3 bg-fg-faint"></span> not applicable</span>
        </p>
      </div>

      <div data-reveal style="transition-delay:100ms">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          From zero to mounted
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">A share in five commands</h2>
        <p class="mt-4 mb-8 text-fg-muted">
          Start the server with <code class="font-mono text-fg">dfs</code>, then
          drive it with <code class="font-mono text-fg">dfsctl</code>: create a
          share, enable a protocol, mount it, write a file. The write lands
          locally and syncs to the remote.
        </p>
        <Terminal />
      </div>
    </div>
  </section>

  <!-- ===================== WRITE PATH ===================== -->
  <section id="write-path" class="section-screen border-t border-border/60 bg-ink-900/40">
    <div class="mx-auto grid max-w-6xl gap-14 px-6 py-24 lg:grid-cols-2 lg:items-center">
      <div data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          The write path
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">Local first, durable second</h2>
        <p class="mt-4 text-fg-muted">
          Every write lands in a local block store and is acknowledged
          immediately, so clients never block on the network. An append-only log
          captures the change first. A background pass then splits it into
          content-defined chunks and addresses each by its BLAKE3 hash, so a
          chunk that already exists is stored once. Those chunks are compressed
          with zstd or lz4, then encrypted under a per-block key before they
          leave the server, so the object store only ever holds deduplicated,
          compressed ciphertext. Only then do blocks sync to durable storage.
          The local tier stays the fast path, the remote is the source of truth.
        </p>
        <ul class="mt-8 space-y-4 text-sm text-fg-muted">
          <li class="flex items-start gap-3">
            <span class="mt-0.5 font-mono text-accent-bright">01</span>
            The client writes to a mounted share. DittoFS appends to a per-file
            log and acks from the local cache right away, with no network round
            trip in the hot path.
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 font-mono text-accent-bright">02</span>
            A rollup splits the log into content-defined chunks (FastCDC),
            addresses each by BLAKE3 hash, and deduplicates against blocks
            already stored.
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 font-mono text-accent-bright">03</span>
            The syncer uploads new blocks to the durable remote, S3 or
            filesystem, optionally compressed and encrypted. Reads verify each
            block by hash.
          </li>
        </ul>
      </div>
      <div class="mx-auto w-full max-w-lg" data-reveal style="transition-delay:90ms">
        <WritePath />
      </div>
    </div>
  </section>

  <!-- ===================== USE CASES ===================== -->
  <section id="use-cases" class="border-t border-border/60">
    <div class="mx-auto max-w-7xl px-6 py-24">
      <div class="max-w-2xl" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          Use cases
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">Where it fits</h2>
        <p class="mt-4 text-fg-muted">
          One server, many shapes. Because protocols and storage are decoupled,
          DittoFS adapts to where your data needs to live.
        </p>
      </div>
      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          useCases.map((u, i) => (
            <div
              class="group relative overflow-hidden rounded-xl border border-border bg-gradient-to-b from-ink-900/80 to-ink-950/40 p-7 transition-all duration-300 hover:-translate-y-1 hover:border-accent/50 hover:shadow-[0_24px_50px_-30px_rgba(0,101,255,0.5)]"
              data-reveal
              style={`transition-delay:${(i % 3) * 70}ms`}
            >
              <div class="flex h-12 w-12 items-center justify-center rounded-xl border border-accent/30 bg-accent/10 text-accent-bright transition-all duration-300 group-hover:scale-110 group-hover:border-accent group-hover:bg-accent/20">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={icons[u.icon]}
                />
              </div>
              <h3 class="mt-5 text-lg font-bold">{u.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-fg-muted">{u.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== ROADMAP ===================== -->
  <section id="roadmap" class="section-screen relative overflow-hidden border-t border-border/60 bg-ink-900/40 scroll-mt-20">
    <div class="bg-grid pointer-events-none absolute inset-0 opacity-[0.18]"></div>
    <div class="relative mx-auto max-w-7xl px-6 py-24">
      <div class="max-w-2xl" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          Built in the open
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">
          Honest about where we are
        </h2>
        <p class="mt-4 text-fg-muted">
          DittoFS is under active development and not yet production-ready. We
          would rather tell you that up front, and show you the path. The core
          works today; we are hardening it toward a 1.0 you can run with
          confidence.
        </p>
      </div>

      <ol class="mt-14 grid gap-5 md:grid-cols-3">
        {
          roadmap.map((col, i) => (
            <li
              class:list={[
                "relative rounded-2xl border p-7",
                col.state === "now"
                  ? "border-accent/50 bg-ink-950/60 shadow-[0_24px_50px_-30px_rgba(0,101,255,0.5)]"
                  : "border-border bg-ink-950/40",
              ]}
              data-reveal
              style={`transition-delay:${i * 80}ms`}
            >
              <div class="flex items-center justify-between">
                <span
                  class:list={[
                    "inline-flex items-center gap-2 rounded-full px-3 py-1 font-mono text-xs uppercase tracking-[0.14em]",
                    col.state === "done" && "bg-accent/15 text-accent-bright",
                    col.state === "now" && "bg-accent text-white",
                    col.state === "planned" && "border border-border-bright text-fg-faint",
                  ]}
                >
                  {col.state === "done" && (
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                  )}
                  {col.state === "now" && (
                    <span class="relative flex h-2 w-2">
                      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-white opacity-70" />
                      <span class="relative inline-flex h-2 w-2 rounded-full bg-white" />
                    </span>
                  )}
                  {col.phase}
                </span>
                <span class="font-mono text-xs text-fg-faint">{col.note}</span>
              </div>
              <ul class="mt-5 space-y-3">
                {col.items.map((item) => (
                  <li class="flex items-start gap-2.5 text-sm text-fg-muted">
                    <span
                      class:list={[
                        "mt-2 h-1.5 w-1.5 shrink-0 rounded-full",
                        col.state === "planned" ? "bg-fg-faint" : "bg-accent-bright",
                      ]}
                    />
                    {item}
                  </li>
                ))}
              </ul>
            </li>
          ))
        }
      </ol>

      <p class="mt-8 text-sm text-fg-faint" data-reveal>
        Follow progress and open issues on
        <a href={GITHUB} target="_blank" rel="noopener" class="text-accent-bright underline-offset-2 hover:underline">GitHub</a>.
      </p>
    </div>
  </section>

  <!-- ===================== PRO TEASER ===================== -->
  <section id="pro" class="border-t border-border/60">
    <div class="mx-auto max-w-2xl px-6 py-24">
      <div
        class="relative overflow-hidden rounded-2xl border border-border-bright bg-gradient-to-br from-ink-800 to-ink-950 px-7 py-9 sm:px-9"
        data-reveal
      >
        <div class="bg-grid pointer-events-none absolute inset-0 opacity-20"></div>
        <div class="relative">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
            DittoFS PRO
          </p>
          <h2 class="mt-3 text-balance text-2xl font-bold sm:text-3xl">
            A management UI and support, on top of the open core
          </h2>
          <p class="mt-4 text-fg-muted">
            The community edition is fully open source. PRO adds a web management
            UI and commercial support for teams that run DittoFS in production.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/pro/" class="btn btn-primary group">
              Explore DittoFS PRO
              <span class="arrow" aria-hidden="true">&rarr;</span>
            </a>
            <a href="/pro/#contact" class="btn btn-secondary"> Request access </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
