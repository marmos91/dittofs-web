      </div>

      <div class="mt-16 grid gap-5 md:grid-cols-3">
        {
          pillars.map((p, i) => (
            <div
              class="rounded-xl border border-border bg-ink-950/60 p-7"
              data-reveal
              style={`transition-delay:${i * 80}ms`}
            >
              <div class="flex h-11 w-11 items-center justify-center rounded-lg border border-accent/30 bg-accent/10 text-accent-bright">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={icons[p.icon]}
                />
              </div>
              <h3 class="mt-5 text-lg font-bold">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-fg-muted">{p.body}</p>
            </div>
