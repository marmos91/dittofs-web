---
import Base from "../layouts/Base.astro";
import Gateway from "../components/landing/Gateway.astro";
import Terminal from "../components/landing/Terminal.astro";
import HowItWorks from "../components/landing/HowItWorks.astro";
import WritePath from "../components/landing/WritePath.astro";
import { getStars, formatStars, getLatestRelease } from "../lib/github";

const GITHUB = "https://github.com/marmos91/dittofs";
const stars = formatStars(await getStars());
const version = await getLatestRelease();

const heroStats = [
  { label: "Versatile", k: "NFS + SMB", v: "served together" },
  { label: "No lock-in", k: "Any S3 backend", v: "multi-cloud" },
  { label: "Zero agents", k: "Native clients", v: "no FUSE, no kernel" },
  { label: "Portable", k: "One binary", v: "pure Go" },
];

// Business outcomes up top: what DittoFS means for a team, before the deep
// technical sections. Each pairs an outcome with the capability that delivers it.
const value = [
  {
    title: "Nothing to deploy on clients",
    body: "DittoFS speaks NFS and SMB natively, so machines mount it with the clients they already ship. No FUSE, no kernel modules, no agent to roll out or keep updated across a fleet.",
    icon: "layers",
  },
  {
    title: "No vendor lock-in",
    body: "Serve the same data from any S3-compatible backend, on any cloud, on-prem, or the edge. Switch providers or go hybrid without re-platforming your applications.",
    icon: "globe",
  },
  {
    title: "No appliance, no licensing",
    body: "Open-source software on hardware you already own. Compute and storage scale on their own, with no proprietary NAS or SAN, no per-shelf fees, and no forklift upgrades.",
    icon: "coins",
  },
  {
    title: "Security you can attest to",
    body: "Client-side encryption, NFSv4 and Windows ACLs, and Kerberos. Running in userspace means no privileged kernel access, and your object store only ever holds ciphertext.",
    icon: "shieldcheck",
  },
];

// Six headline capabilities get full cards; the rest sit in a compact list
// below so the section reads as "six reasons + the long tail," not a wall of 11.
const features = [
  {
    tag: "protocols",
    title: "Multi-protocol, one server",
    body: "NFS and SMB run at the same time on the same server, serving the same files to Linux, Windows, and macOS.",
    icon: "layers",
  },
  {
    tag: "backends",
    title: "Pluggable storage",
    body: "Mix metadata stores (memory, BadgerDB, PostgreSQL) and block stores (filesystem, S3) per share.",
    icon: "plug",
  },
  {
    tag: "runtime",
    title: "Runs in userspace",
    body: "No FUSE, no kernel modules, no root. DittoFS runs as an ordinary process you can start anywhere.",
    icon: "shield",
  },
  {
    tag: "security",
    title: "Client-side encryption",
    body: "Per-remote envelope encryption with AES-256-GCM or ChaCha20-Poly1305, keyed locally or via KMIP. Blocks are encrypted before they leave the server, so the object store only sees ciphertext.",
    icon: "lock",
  },
  {
    tag: "efficiency",
    title: "Deduplication",
    body: "Files split into content-defined chunks, addressed by BLAKE3 hash. Identical chunks across files are stored once.",
    icon: "dedup",
  },
  {
    tag: "control plane",
    title: "REST control plane",
    body: "Manage users, groups, and shares through a JWT-authenticated REST API or the dfsctl command line. Provision by script, not by editing config files.",
    icon: "code",
  },
];

// The long tail, shown as a tighter list under the six cards.
const featuresMore = [
  {
    title: "Easy to containerize",
    body: "One static Go binary drops into any container or orchestrator.",
    icon: "container",
  },
  {
    title: "Compression",
    body: "Remote block stores compress with zstd or lz4 before upload.",
    icon: "compress",
  },
  {
    title: "Share snapshots",
    body: "Point-in-time holds with no data copy. Restore from CLI or REST.",
    icon: "camera",
  },
  {
    title: "Kerberos and signing",
    body: "RPCSEC_GSS, SPNEGO Kerberos, SMB3 signing and transport encryption.",
    icon: "key",
  },
  {
    title: "Cross-platform ACLs",
    body: "NFSv4 and Windows/SMB ACLs enforced consistently across clients.",
    icon: "shieldcheck",
  },
  {
    title: "Cross-protocol xattrs",
    body: "Extended attributes (RFC 8276 over NFSv4.2, native over SMB) read and write the same values across protocols.",
    icon: "layers",
  },
];

// Honest protocol capability matrix. y = yes, p = partial, n = not applicable.
const matrixCols = ["NFSv3", "NFSv4.1 / 4.2", "SMB2 / 3"];
const matrixRows = [
  { label: "Mount & file I/O", v: ["y", "y", "y"] },
  { label: "ACLs", v: ["n", "y", "y"] },
  { label: "Extended attributes", v: ["n", "y", "y"] },
  { label: "Kerberos auth", v: ["y", "y", "y"] },
  { label: "Leases / delegations", v: ["n", "y", "y"] },
  { label: "Wire encryption", v: ["p", "p", "y"] },
  { label: "Client-side encryption", v: ["y", "y", "y"] },
  { label: "Snapshots", v: ["y", "y", "y"] },
];

const useCases = [
  {
    title: "Multi-tenant cloud",
    body: "Host many tenants on shared infrastructure without crossing streams. Isolated shares, per-tenant stores, and client-side encryption keep data separated.",
    icon: "globe",
  },
  {
    title: "Tiered storage",
    body: "Keep hot data fast and cold data cheap. A local cache fronts durable S3, so users hit the local tier while data syncs to the remote in the background.",
    icon: "swap",
  },
  {
    title: "Hybrid Linux and Windows",
    body: "Consolidate mixed fleets onto one server. Linux over NFS, Windows and macOS over SMB, all serving the same data instead of running parallel systems.",
    icon: "layers",
  },
  {
    title: "Dev and test",
    body: "Ship faster with a throwaway filesystem in one command. In-memory, no FUSE, no privileges, nothing external to provision.",
    icon: "beaker",
  },
  {
    title: "Cloud-native deployments",
    body: "Drop a single userspace binary into Kubernetes with the operator. Scale shares, not kernels, with no privileged DaemonSets to maintain.",
    icon: "container",
  },
  {
    title: "Backup and recovery",
    body: "Guard against accidental deletes with point-in-time snapshots that copy no data, restorable from the CLI or REST API in seconds.",
    icon: "camera",
  },
];

const backends = [
  "AWS S3",
  "Cubbit DS3",
  "MinIO",
  "Ceph",
  "Wasabi",
  "Backblaze B2",
  "Scaleway",
  "Filesystem",
  "any S3-compatible",
];

const pillars = [
  {
    title: "Multi-cloud and hybrid",
    body: "Serve the same data from AWS, MinIO, Ceph, Cubbit DS3, or a local disk. Move between clouds and the edge without re-platforming.",
    icon: "globe",
  },
  {
    title: "No appliance to buy",
    body: "Run it on commodity hardware or a VM you already pay for. There is no NAS controller to size and no capacity to license up front, and compute scales separately from the storage behind it.",
    icon: "coins",
  },
  {
    title: "Runs anywhere",
    body: "One static binary on a laptop, a bare-metal edge box, a VM in any cloud, or Kubernetes with the official operator.",
    icon: "cpu",
  },
];

const roadmap = [
  {
    phase: "Shipped",
    state: "done",
    note: "Working today",
    items: [
      "Multi-protocol engine: NFSv3/v4/4.1/4.2 and SMB2/3",
      "Pluggable metadata and block stores",
      "Client-side encryption, dedup, and compression",
      "REST control plane, CLI, and Kubernetes operator",
    ],
  },
  {
    phase: "In progress",
    state: "now",
    note: "Where we are",
    items: [
      "Stability and performance hardening",
      "Wider test coverage and benchmarks",
      "Deployment guides and reference docs",
    ],
  },
  {
    phase: "Next",
    state: "planned",
    note: "What's coming",
    items: [
      "Production-ready 1.0",
      "Managed PRO console with role-based access",
      "Commercial support tiers",
    ],
  },
];

const icons: Record<string, string> = {
  shield: `<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/>`,
  layers: `<path d="M12 3l9 5-9 5-9-5 9-5z"/><path d="M3 12l9 5 9-5"/>`,
  plug: `<path d="M9 3v6M15 3v6"/><path d="M7 9h10v3a5 5 0 0 1-10 0V9z"/><path d="M12 17v4"/>`,
  lock: `<rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/>`,
  camera: `<path d="M3 8h4l2-2h6l2 2h4v12H3V8z"/><circle cx="12" cy="13" r="3.5"/>`,
  container: `<path d="M12 2l8 4.5v9L12 20l-8-4.5v-9L12 2z"/><path d="M12 11l8-4.5M12 11v9M12 11L4 6.5"/>`,
  dedup: `<rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/>`,
  compress: `<path d="M8 4v4H4M16 4v4h4M8 20v-4H4M16 20v-4h4"/>`,
  key: `<circle cx="8" cy="8" r="4"/><path d="M11 11l9 9M17 17l2-2M14 14l2-2"/>`,
  shieldcheck: `<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 11l2 2 4-4"/>`,
  code: `<path d="M8 4l-4 8 4 8M16 4l4 8-4 8"/>`,
  globe: `<circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3c2.6 2.7 2.6 15.3 0 18M12 3c-2.6 2.7-2.6 15.3 0 18"/>`,
  swap: `<path d="M4 9h13l-4-4M20 15H7l4 4"/>`,
  beaker: `<path d="M9 3h6M10 3v6L5 19a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1l-5-10V3"/><path d="M7.5 14h9"/>`,
  coins: `<ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6"/><path d="M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6"/>`,
  cpu: `<rect x="6" y="6" width="12" height="12" rx="2"/><rect x="9.5" y="9.5" width="5" height="5" rx="1"/><path d="M9 2v2.5M15 2v2.5M9 19.5V22M15 19.5V22M2 9h2.5M2 15h2.5M19.5 9H22M19.5 15H22"/>`,
};

const statusMark = (s: string) =>
  s === "y" ? "supported" : s === "p" ? "partial" : "not applicable";
---

<Base>
  <!-- ===================== HERO ===================== -->
  <section class="relative overflow-hidden">
    <div class="bg-grid pointer-events-none absolute inset-0 opacity-[0.35]"></div>
    <div
      class="glow-accent pointer-events-none absolute -top-32 left-1/2 h-[560px] w-[920px] -translate-x-1/2 opacity-50"
    >
    </div>

    <div
      class="relative mx-auto grid w-full max-w-7xl items-center gap-10 px-6 py-20 lg:grid-cols-[1fr_1.18fr] lg:py-28"
    >
      <div>
        <div class="rise mb-5 flex flex-wrap items-center gap-3">
          <a
            href="/#roadmap"
            class="inline-flex items-center gap-2 rounded-full border border-accent/30 bg-accent/10 px-3.5 py-1.5 text-sm font-medium text-accent-bright transition-colors hover:border-accent/60 hover:bg-accent/15"
          >
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-bright opacity-60"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-bright"></span>
            </span>
            Building in the open
            <span aria-hidden="true">&rarr;</span>
          </a>
          <a
            href={`${GITHUB}/releases`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 rounded-full border border-border-bright px-3 py-1.5 font-mono text-xs text-fg-muted transition-colors hover:border-accent/50 hover:text-fg"
            data-gh-version
            hidden={!version}
            aria-label="Latest DittoFS release"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r="1.2" fill="currentColor"/></svg>
            <span class="gh-version-n">{version}</span>
          </a>
        </div>
        <h1
          class="rise text-balance text-4xl font-bold leading-[1.04] tracking-tight sm:text-5xl lg:text-6xl"
        >
          One filesystem.<br />
          <span class="text-accent-bright">Every protocol.</span> Any backend.
        </h1>
        <p
          class="rise mt-6 max-w-xl text-pretty text-lg leading-relaxed text-fg-muted"
          style="animation-delay:80ms"
        >
          Simple to run, versatile by design. DittoFS serves your files over NFS
          and SMB with no client agents to install, and stores them on any
          backend you choose, from local disk to S3. No FUSE, no kernel modules,
          no appliance.
        </p>

        <div
          class="rise mt-9 flex flex-wrap items-center gap-4"
          style="animation-delay:160ms"
        >
          <a href="/docs/getting-started/getting-started/" class="btn btn-primary group">
            Get started
            <span class="arrow" aria-hidden="true">&rarr;</span>
          </a>
          <a href={GITHUB} target="_blank" rel="noopener" class="btn btn-secondary">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"
              ><path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
              ></path></svg
            >
            View on GitHub
            <span
              class="ml-1 flex items-center gap-1 border-l border-border-bright pl-2.5 font-mono text-[13px] tabular-nums text-fg-faint"
              data-gh-stars
              hidden={!stars}
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01L12 2z"/></svg>
              <span class="gh-stars-n">{stars}</span>
            </span>
          </a>
        </div>

      </div>

      <div class="rise" style="animation-delay:140ms">
        <Gateway />
      </div>
    </div>

    <!-- Spec strip sits flush under the hero content as its base band. Darker
         than the next section so it reads as the hero's footer, not its start. -->
    <div class="relative border-t border-border/60 bg-ink-950/60 pb-6 sm:pb-8">
      <div class="mx-auto max-w-7xl px-6">
        <dl class="grid grid-cols-2 divide-border sm:grid-cols-4 sm:divide-x">
          {
            heroStats.map((s, i) => (
              <div
                class:list={[
                  "px-4 py-5 sm:px-6",
                  i >= 2 && "border-t border-border sm:border-t-0",
                  i % 2 === 1 && "border-l border-border sm:border-l-0",
                ]}
              >
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-accent-bright">
                  {s.label}
                </p>
                <dt class="mt-2 text-sm font-bold leading-none text-fg">{s.k}</dt>
                <dd class="mt-1.5 text-xs leading-tight text-fg-faint">{s.v}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <!-- ===================== VALUE (BUSINESS OUTCOMES) ===================== -->
  <section id="why" class="section-screen border-t border-border/60 bg-ink-900/40">
    <div class="mx-auto max-w-7xl px-6 py-24">
      <div class="mx-auto max-w-2xl text-center" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          Why teams choose DittoFS
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">
          Network storage without the usual baggage
        </h2>
        <p class="mt-4 text-fg-muted">
          Standard protocols, your own backends, and nothing proprietary in the
          path. Fewer moving parts to deploy, secure, and pay for.
        </p>
      </div>

      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          value.map((v, i) => (
            <div
              class="rounded-2xl border border-border bg-ink-950/50 p-7"
              data-reveal
              style={`transition-delay:${(i % 4) * 70}ms`}
            >
              <div class="flex h-11 w-11 items-center justify-center rounded-lg border border-accent/30 bg-accent/10 text-accent-bright">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={icons[v.icon]}
                />
              </div>
              <h3 class="mt-5 text-base font-bold">{v.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-fg-muted">{v.body}</p>
            </div>
          ))
        }
      </div>

      <!-- How it's different (generic, unnamed contrast) -->
      <div class="mt-12 grid gap-5 md:grid-cols-2" data-reveal>
        <div class="rounded-2xl border border-border bg-ink-950/40 p-7">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-fg-faint">
            Other network filesystems
          </p>
          <ul class="mt-5 space-y-3 text-sm text-fg-muted">
            <li class="flex items-start gap-3">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-fg-faint" />
              Install a kernel driver (FUSE) on every client, with privileged access
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-fg-faint" />
              Or rewrite applications against a language-specific SDK
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-fg-faint" />
              An agent to deploy, update, and troubleshoot on every machine
            </li>
          </ul>
        </div>
        <div class="rounded-2xl border border-accent/40 bg-gradient-to-br from-ink-800 to-ink-950 p-7">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent-bright">
            DittoFS
          </p>
          <ul class="mt-5 space-y-3 text-sm text-fg">
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-accent-bright">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              Speaks NFS and SMB natively, the clients every OS already ships
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-accent-bright">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              No application changes. Mount a share and read and write files
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-accent-bright">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              Nothing privileged to run, nothing per-machine to manage
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FEATURES ===================== -->
  <section id="features" class="section-screen border-t border-border/60">
    <div class="mx-auto max-w-7xl px-6 py-24">
      <div class="max-w-2xl" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          Why DittoFS
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">
          Storage decisions, decoupled from protocols
        </h2>
        <p class="mt-4 text-fg-muted">
          Decouple the interface your clients speak from the backend your data
          lives on, per share, so storage choices never dictate how teams
          connect.
        </p>
      </div>

      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          features.map((f, i) => (
            <div
              class="group relative overflow-hidden rounded-lg border border-border bg-ink-950/50 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent/50 hover:bg-ink-900/60 hover:shadow-[0_24px_50px_-30px_rgba(0,101,255,0.5)]"
              data-reveal
              style={`transition-delay:${(i % 3) * 70}ms`}
            >
              <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
              <div
                class="glow-accent pointer-events-none absolute -right-10 -top-10 h-32 w-32 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
              />
              <div class="relative flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-md border border-accent/30 bg-accent/10 text-accent-bright transition-all duration-300 group-hover:border-accent group-hover:bg-accent/20">
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={icons[f.icon]}
                  />
                </div>
                <span class="font-mono text-xs text-fg-faint">
                  {String(i + 1).padStart(2, "0")}
                </span>
              </div>
              <p class="relative mt-5 font-mono text-[11px] uppercase tracking-[0.18em] text-accent-bright/80">
                {f.tag}
              </p>
              <h3 class="relative mt-1.5 text-base font-bold">{f.title}</h3>
              <p class="relative mt-2 text-sm leading-relaxed text-fg-muted">{f.body}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-12 border-t border-border/60 pt-10" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-fg-faint">
          And more
        </p>
