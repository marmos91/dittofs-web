  <!-- ===================== NO LOCK-IN ===================== -->
  <section id="storage" class="section-screen relative overflow-hidden border-t border-border/60">
    <div class="bg-grid pointer-events-none absolute inset-0 opacity-[0.22]"></div>
    <div
      class="glow-accent pointer-events-none absolute left-1/2 top-10 h-[360px] w-[760px] -translate-x-1/2 opacity-30"
    >
    </div>
    <div class="relative mx-auto max-w-7xl px-6 py-24">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          No lock-in
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">
          Object storage, with filesystem semantics
        </h2>
        <p class="mt-4 text-fg-muted">
          DittoFS puts real NFS and SMB on top of any S3-compatible object store.
          Serve the same bucket from any cloud, on-prem, or the edge. Your data
          follows your architecture, not a vendor.
        </p>
      </div>

      <div class="mt-12" data-reveal>
        <p class="text-center font-mono text-xs uppercase tracking-[0.2em] text-fg-faint">
          Bring your own backend
        </p>
        <div class="mx-auto mt-6 flex max-w-4xl flex-wrap items-center justify-center gap-3">
          {
            backends.map((b) => (
              <span class="rounded-lg border border-border-bright bg-ink-900 px-4 py-2 text-sm text-fg-muted transition-colors hover:border-accent hover:text-fg">
                {b}
              </span>
            ))
          }
          <a
            href="/docs/contributing/implementing-stores/"
            class="group inline-flex items-center gap-1.5 rounded-lg border border-dashed border-accent/70 bg-accent/10 px-4 py-2 text-sm font-medium text-accent-bright transition-colors hover:border-accent hover:bg-accent/20"
          >
            + write your own
            <span class="arrow" aria-hidden="true">&rarr;</span>
