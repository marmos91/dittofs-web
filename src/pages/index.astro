        </p>
      </div>

      <ol class="mt-14 grid gap-5 md:grid-cols-3">
        {
          roadmap.map((col, i) => (
            <li
              class:list={[
                "relative rounded-2xl border p-7",
                col.state === "now"
                  ? "border-accent/50 bg-ink-950/60 shadow-[0_24px_50px_-30px_rgba(0,101,255,0.5)]"
                  : "border-border bg-ink-950/40",
              ]}
              data-reveal
              style={`transition-delay:${i * 80}ms`}
            >
              <div class="flex items-center justify-between">
                <span
                  class:list={[
                    "inline-flex items-center gap-2 rounded-full px-3 py-1 font-mono text-xs uppercase tracking-[0.14em]",
                    col.state === "done" && "bg-accent/15 text-accent-bright",
                    col.state === "now" && "bg-accent text-white",
                    col.state === "planned" && "border border-border-bright text-fg-faint",
                  ]}
                >
                  {col.state === "done" && (
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                  )}
                  {col.state === "now" && (
                    <span class="relative flex h-2 w-2">
                      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-white opacity-70" />
                      <span class="relative inline-flex h-2 w-2 rounded-full bg-white" />
