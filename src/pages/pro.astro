---
import Base from "../layouts/Base.astro";
import BrowserFrame from "../components/BrowserFrame.astro";

const community = [
  "All protocols: NFSv3, NFSv4, NFSv4.1, SMB2/3",
  "All stores: memory, BadgerDB, PostgreSQL, filesystem, S3",
  "Client-side encryption and Kerberos",
  "Share snapshots and restore",
  "REST API, CLI, and Kubernetes operator",
  "Community support on GitHub",
];

// PRO is the community edition plus these. The "everything in community" base
// is stated once as a header line, not repeated as a bullet.
const pro = [
  "Web management UI for users, shares, and stores",
  "Role-based administration",
  "Commercial support with response-time commitments",
  "Guided upgrades and migration help",
  "Priority fixes and direct access to the team",
];

// Early-access perks: the human side of PRO, beyond the feature list.
const perks = [
  {
    title: "Shape the roadmap",
    body: "A direct line to the team. What you need steers what we build next.",
    icon: `<circle cx="12" cy="12" r="9"/><path d="M14.5 9.5l-2 5-5 2 2-5 5-2z"/>`,
  },
  {
    title: "Guided onboarding",
    body: "Hands-on help designing shares and stores, and planning your migration.",
    icon: `<path d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3z"/><path d="M12 12l8-4.5M12 12v9M12 12L4 7.5"/>`,
  },
  {
    title: "Priority everything",
    body: "Fixes, response-time commitments, and upgrades ahead of the queue.",
    icon: `<path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/>`,
  },
];
---

<Base
  title="DittoFS PRO · management UI and commercial support"
  description="DittoFS PRO adds a web management UI and commercial support on top of the open-source community edition. Talk to us about running DittoFS in production."
>
  <!-- HERO -->
  <section class="section-screen relative overflow-hidden border-b border-border/60">
    <div class="bg-grid pointer-events-none absolute inset-0 opacity-[0.3]"></div>
    <div
      class="glow-accent pointer-events-none absolute -top-24 left-1/2 h-[440px] w-[760px] -translate-x-1/2 opacity-40"
    >
    </div>
    <div class="relative mx-auto max-w-4xl px-6 py-24 text-center">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
        DittoFS PRO
      </p>
      <h1 class="mt-4 text-balance text-5xl font-bold leading-[1.05] sm:text-6xl">
        The open core, with a team behind it
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-fg-muted">
        The community edition is fully open source and always will be. PRO adds
        a web management UI and commercial support for teams that want to run
        DittoFS at work. We are onboarding early-access partners now, in limited
        numbers, to shape it together.
      </p>
      <div class="mt-9 flex flex-wrap justify-center gap-4">
        <a
          href="#contact"
          class="btn btn-primary"
        >
          Request early access
        </a>
        <a
          href="/docs/overview/getting-started/"
          class="btn btn-secondary"
        >
          Try the community edition
        </a>
      </div>
      <p class="mt-5 flex items-center justify-center gap-2 font-mono text-xs text-fg-faint">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-bright opacity-60"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-bright"></span>
        </span>
        Limited onboarding slots &middot; by invitation
      </p>
    </div>
  </section>

  <!-- INTERFACE / SCREENSHOTS -->
  <section class="section-screen border-b border-border/60 bg-ink-900/40">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <div class="mx-auto max-w-2xl text-center" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          The interface
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">
          A web console for your deployment
        </h2>
        <p class="mt-4 text-fg-muted">
          Manage users, shares, stores, and protocol adapters from one place,
          backed by the same engine you run in the community edition.
        </p>
      </div>

      <div class="mt-12" data-reveal>
        <BrowserFrame
          src="/pro/dashboard.png"
          alt="DittoFS PRO dashboard showing shares, stores, adapters, and server health"
          label="dittofs · dashboard"
          width={1622}
          height={1023}
        />
      </div>
    </div>
  </section>

  <!-- EARLY ACCESS PERKS -->
  <section class="section-screen border-b border-border/60">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <div class="mx-auto max-w-2xl text-center" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          Early access
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold sm:text-4xl">
          More than a license
        </h2>
        <p class="mt-4 text-fg-muted">
          We are onboarding a small group of partners. You get the people behind
          DittoFS, not just the software.
        </p>
      </div>

      <div class="mt-14 grid gap-5 md:grid-cols-3">
        {
          perks.map((p, i) => (
            <div
              class="rounded-2xl border border-border bg-ink-950/50 p-7"
              data-reveal
              style={`transition-delay:${i * 80}ms`}
            >
              <div class="flex h-11 w-11 items-center justify-center rounded-lg border border-accent/30 bg-accent/10 text-accent-bright">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={p.icon}
                />
              </div>
              <h3 class="mt-5 text-lg font-bold">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-fg-muted">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="section-screen border-b border-border/60">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <div class="mx-auto max-w-2xl text-center" data-reveal>
        <h2 class="text-3xl font-bold sm:text-4xl">Community and PRO</h2>
        <p class="mt-4 text-fg-muted">
          Same engine. PRO adds the tooling and support that production teams ask
          for.
        </p>
      </div>

      <div class="mt-14 grid gap-6 lg:grid-cols-2">
        <div class="rounded-2xl border border-border bg-ink-900 p-8" data-reveal>
          <h3 class="text-xl font-bold">Community</h3>
          <p class="mt-1 text-sm text-fg-faint">Open source, MIT licensed</p>
          <ul class="mt-6 space-y-3">
            {
              community.map((item) => (
                <li class="flex items-start gap-3 text-sm text-fg-muted">
                  <span class="mt-1 text-accent-bright">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  </span>
                  {item}
                </li>
              ))
            }
          </ul>
          <a
            href="/docs/overview/getting-started/"
            class="mt-8 inline-block rounded-md border border-border-bright px-5 py-2.5 text-sm font-semibold text-fg transition-colors hover:bg-ink-800"
          >
            Get started
          </a>
        </div>

        <div
          class="relative overflow-hidden rounded-2xl border-2 border-accent/60 bg-gradient-to-br from-ink-800 to-ink-950 p-8 shadow-[0_30px_70px_-40px_rgba(0,101,255,0.7)] lg:-mt-3 lg:-mb-3"
          data-reveal
          style="transition-delay:90ms"
        >
          <div class="bg-grid pointer-events-none absolute inset-0 opacity-15"></div>
          <div class="relative">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
              <h3 class="text-xl font-bold">PRO</h3>
              <span class="rounded-full bg-accent/15 px-2.5 py-0.5 font-mono text-xs text-accent-bright">
                early access
              </span>
              <span class="ml-auto rounded-full bg-accent px-3 py-1 font-mono text-xs font-semibold uppercase tracking-[0.12em] text-white">
                Recommended
              </span>
            </div>
            <p class="mt-1 text-sm text-fg-faint">UI and support on the open core</p>
            <p class="mt-6 text-sm font-semibold text-fg">Everything in Community, plus</p>
            <ul class="mt-4 space-y-3">
              {
                pro.map((item) => (
                  <li class="flex items-start gap-3 text-sm text-fg">
                    <span class="mt-1 text-accent-bright">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    </span>
                    {item}
                  </li>
                ))
              }
            </ul>
            <a
              href="#contact"
              class="mt-8 inline-block rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent-bright"
            >
              Request access
            </a>
            <p class="mt-3 font-mono text-xs text-fg-faint">
              Limited onboarding slots &middot; by invitation
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section-screen scroll-mt-20">
    <div class="mx-auto grid max-w-6xl gap-14 px-6 py-24 lg:grid-cols-2 lg:items-start">
      <div data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-bright">
          Get in touch
        </p>
        <h2 class="mt-3 text-3xl font-bold sm:text-4xl">Tell us what you need</h2>
        <p class="mt-4 text-fg-muted">
          Whether you are evaluating DittoFS or already running it, we can help
          with the management UI, support terms, and rollout. Send a note and we
          will get back to you.
        </p>
        <ul class="mt-8 space-y-4 text-sm text-fg-muted">
          <li class="flex items-start gap-3">
            <span class="mt-0.5 font-mono text-accent-bright">01</span>
            Share your deployment shape and what you want from PRO.
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 font-mono text-accent-bright">02</span>
            We follow up by email, usually within a couple of business days.
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 font-mono text-accent-bright">03</span>
            We scope the UI access and support that fits your team.
          </li>
        </ul>
      </div>

      <div class="hs-dark rounded-2xl border border-border bg-ink-900 p-8" data-reveal style="transition-delay:90ms">
        {/* HubSpot form, tracked by the marketing team. Inline embed (not the
            iframe loader) so the form renders real DOM we can theme for dark mode.
            Same portal and form id, so tracking is unchanged. */}
        <div id="hubspot-pro-form"></div>
        <script src="https://js.hsforms.net/forms/embed/v2.js" is:inline></script>
        <script is:inline>
          (function () {
            function mount() {
              if (!window.hbspt) return false;
              window.hbspt.forms.create({
                region: "na1",
                portalId: "7784331",
                formId: "9f568ad6-dc8b-4063-9c02-6fb5b56332e2",
                target: "#hubspot-pro-form",
                redirectUrl: "/thank-you",
              });
              return true;
            }
            if (!mount()) {
              var t = setInterval(function () {
                if (mount()) clearInterval(t);
              }, 100);
            }
          })();
        </script>
      </div>
    </div>
  </section>
</Base>
