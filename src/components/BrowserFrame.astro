---
/* A browser-window frame for product screenshots. */
interface Props {
  src: string;
  alt: string;
  label?: string;
  width: number;
  height: number;
}
const {
  src,
  alt,
  label = "dittofs · management",
  width,
  height,
} = Astro.props;
---

<figure class="group m-0 overflow-hidden rounded-xl border border-border-bright bg-ink-900 shadow-[0_40px_90px_-50px_rgba(0,0,0,0.95)] transition-transform duration-300 hover:-translate-y-1">
  <div class="flex items-center gap-1.5 border-b border-border bg-ink-950/70 px-4 py-2.5">
    <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
    <span class="ml-3 truncate rounded bg-ink-800 px-3 py-1 font-mono text-[11px] text-fg-faint">
      {label}
    </span>
  </div>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading="lazy"
    decoding="async"
    class="block w-full"
  />
</figure>
