---
/*
  Consent-gated analytics. A GDPR cookie banner (vanilla-cookieconsent) gates
  Google Tag Manager (analytics category). Nothing loads until the visitor opts
  in. The GTM container ID comes from the PUBLIC_GTM_ID env var.
*/
const gtmId = import.meta.env.PUBLIC_GTM_ID ?? "";
---

<span id="dfs-analytics-config" data-gtm={gtmId} hidden></span>

<script>
  import "vanilla-cookieconsent/dist/cookieconsent.css";
  import * as CookieConsent from "vanilla-cookieconsent";

  const cfg = document.getElementById("dfs-analytics-config");
  const GTM = cfg?.dataset.gtm || "";

  let gtmLoaded = false;

  function loadGTM() {
    if (gtmLoaded || !GTM) return;
    gtmLoaded = true;
    const w = window as any;
    w.dataLayer = w.dataLayer || [];
    w.dataLayer.push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
    const s = document.createElement("script");
    s.async = true;
    s.src = "https://www.googletagmanager.com/gtm.js?id=" + GTM;
    document.head.appendChild(s);
  }

  function applyConsent() {
    if (CookieConsent.acceptedCategory("analytics")) loadGTM();
  }

  CookieConsent.run({
    guiOptions: {
      consentModal: { layout: "box", position: "bottom left" },
      preferencesModal: { layout: "box" },
    },
    categories: {
      necessary: { enabled: true, readOnly: true },
      analytics: {},
    },
    onConsent: applyConsent,
    onChange: applyConsent,
    language: {
      default: "en",
      translations: {
        en: {
          consentModal: {
            title: "We value your privacy",
            description:
              "We use cookies to understand how the site is used. Necessary cookies keep the site working. You can accept or reject analytics.",
            acceptAllBtn: "Accept all",
            acceptNecessaryBtn: "Reject optional",
            showPreferencesBtn: "Manage choices",
            footer: '<a href="/privacy/">Privacy</a><a href="/cookie-policy/">Cookie policy</a>',
          },
          preferencesModal: {
            title: "Cookie preferences",
            acceptAllBtn: "Accept all",
            acceptNecessaryBtn: "Reject optional",
            savePreferencesBtn: "Save choices",
            closeIconLabel: "Close",
            sections: [
              {
                title: "Necessary",
                description:
                  "Required for the site to function. These are always on.",
                linkedCategory: "necessary",
              },
              {
                title: "Analytics",
                description:
                  "Google Tag Manager and the tags it manages, used to measure traffic and usage.",
                linkedCategory: "analytics",
              },
              {
                title: "More information",
                description:
                  'See our <a href="/cookie-policy/">cookie policy</a> for details.',
              },
            ],
          },
        },
      },
    },
  });

  (window as any).openCookiePreferences = () => CookieConsent.showPreferences();
</script>

<style is:global>
  :root {
    --cc-bg: #0d1a30;
    --cc-text: #e8eefb;
    --cc-btn-primary-bg: #0065ff;
    --cc-btn-primary-hover-bg: #3d8bff;
    --cc-btn-primary-text: #ffffff;
    --cc-btn-secondary-bg: #11203c;
    --cc-btn-secondary-hover-bg: #16294a;
    --cc-btn-secondary-text: #e8eefb;
    --cc-separator-border-color: #1b2942;
    --cc-toggle-on-bg: #0065ff;
    --cc-cookie-category-block-bg: #081020;
    --cc-cookie-category-block-border: #1b2942;
    --cc-link-color: #3d8bff;
    --cc-modal-border-radius: 14px;
    --cc-btn-border-radius: 8px;
    --cc-font-family: "Source Sans 3 Variable", system-ui, sans-serif;
  }
</style>
