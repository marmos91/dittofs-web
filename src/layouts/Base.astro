---
// Base layout for marketing pages. Docs pages use Starlight's own layout.
import "@fontsource/titillium-web/300.css";
import "@fontsource/titillium-web/400.css";
import "@fontsource/titillium-web/600.css";
import "@fontsource/titillium-web/700.css";
import "@fontsource/titillium-web/900.css";
import "@fontsource-variable/source-sans-3";
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Analytics from "../components/Analytics.astro";

// Only mount the consent banner + tags when analytics is actually configured.
const enableAnalytics = !!(
  import.meta.env.PUBLIC_GTM_ID || import.meta.env.PUBLIC_FB_PIXEL_ID
);

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "DittoFS — NFS and SMB in userspace, with pluggable storage",
  description = "DittoFS is a modular virtual filesystem in Go. Serve files over NFSv3/v4/v4.1 and SMB2/3 from pluggable metadata and block stores. No FUSE, no kernel modules, single binary.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/og/default.png", Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: "DittoFS",
        applicationCategory: "DeveloperApplication",
        operatingSystem: "Linux, macOS, Windows",
        description:
          "Modular virtual filesystem in Go. Serves files over NFSv3/v4/v4.1 and SMB2/3 from pluggable metadata and block stores.",
        url: Astro.site?.href,
        license: "https://opensource.org/licenses/MIT",
        offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      })}
    />
  </head>
  <body class="min-h-screen">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    {enableAnalytics && <Analytics />}

    <script>
      // Reveal elements as they scroll into view.
      const els = document.querySelectorAll<HTMLElement>("[data-reveal]");
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: "0px 0px -10% 0px" },
      );
      els.forEach((el) => io.observe(el));
    </script>
  </body>
</html>
